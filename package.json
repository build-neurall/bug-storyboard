{"name": "bug-storyboard", "version": "0.1.0", "private": true, "description": "Frontend debugging tool that records state changes, user actions, and errors before a bug occurs", "scripts": {"dev": "pnpm run --parallel dev:*", "dev:sdk": "pnpm --filter @neurall/bug-storyboard-sdk dev", "dev:collector": "pnpm --filter @neurall/bug-storyboard-collector dev", "dev:viewer": "pnpm --filter @neurall/bug-storyboard-viewer dev", "build": "pnpm run --parallel build", "build:sdk": "pnpm --filter @neurall/bug-storyboard-sdk build", "build:collector": "pnpm --filter @neurall/bug-storyboard-collector build", "build:viewer": "pnpm --filter @neurall/bug-storyboard-viewer build"}, "keywords": ["debugging", "react", "timeline", "frontend"], "author": "Neurall", "license": "MIT"}